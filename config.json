{
    "arch": {
        "args": {
            "backbone": "resnet18",
            "freeze_backbone": false,
            "freeze_bn": false
        },
        "type": "DeepLab"
    },
    "ignore_index": 255,
    "loss": "CrossEntropyLoss2d",
    "lr_scheduler": {
        "args": {},
        "type": "Poly"
    },
    "n_gpu": 2,
    "name": "ResNet",
    "optimizer": {
        "args": {
            "lr": 0.01,
            "momentum": 0.9,
            "weight_decay": 0.0001
        },
        "differential_lr": true,
        "type": "SGD"
    },
    "train_loader": {
        "args": {
            "augment": true,
            "base_size": null,
            "batch_size": 8,
            "blur": true,
            "crop_size": 800,
            "data_dir": "./data",
            "flip": true,
            "num_workers": 4,
            "rotate": true,
            "scale": true,
            "shuffle": true,
            "split": "train"
        },
        "type": "VOC"
    },
    "trainer": {
        "early_stop": 10,
        "epochs": 500,
        "log_dir": "saved/runs",
        "log_per_iter": 20,
        "monitor": "max Mean_IoU",
        "save_dir": "saved/",
        "save_period": 5,
        "tensorboard": true,
        "val": true,
        "val_per_epochs": 5
    },
    "use_synch_bn": false,
    "val_loader": {
        "args": {
            "batch_size": 4,
            "crop_size": 800,
            "data_dir": "./data",
            "num_workers": 4,
            "split": "val",
            "val": true
        },
        "type": "VOC"
    }
}